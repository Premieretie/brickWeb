# ============================================================
# BrickQuote Pro — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# On the production Windows Server, create a file at:
#   C:\inetpub\brickquotepro\.env
# and copy the contents below with real values.
#
# NEVER commit .env.local, .env, or any file with real secrets to git.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only — used for admin actions like creating contractor profiles
# Found in: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (only needed when subscription billing is active) ─
# Found in: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe price IDs (replace with your own from Stripe Dashboard → Products → Prices)
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxxxx

# ── Application ─────────────────────────────────────────────
# Public URL of the deployed site (no trailing slash)
# Used by Next.js for metadata, canonical URLs, and redirects.
NEXT_PUBLIC_SITE_URL=https://brickquotepro.com

# Internal application URL used by deployment scripts and backend logic.
# On Windows Server + IIS this should match the public domain.
APP_URL=https://brickquotepro.com

# Node environment (set automatically by Next.js)
# NODE_ENV=production
