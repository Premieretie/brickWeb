# ============================================================
# BrickQuote Pro — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# On the production server, set these as system environment
# variables or pass them to the Docker container at runtime.
#
# NEVER commit .env.local or any file with real secrets to git.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Stripe (optional — only needed when payments are active) ─
# Found in: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── Application ─────────────────────────────────────────────
# Public URL of the deployed site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://brickquotepro.com

# Node environment (set automatically by Next.js)
# NODE_ENV=production
