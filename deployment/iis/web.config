<?xml version="1.0" encoding="UTF-8"?>
<!-- ========================================================== -->
<!-- BrickQuote Pro — IIS + ARR reverse proxy configuration      -->
<!-- Place at: C:\inetpub\brickquotepro\site\web.config           -->
<!-- Requires: URL Rewrite 2.1 + Application Request Routing 3.0 -->
<!-- Target:   Next.js app on http://127.0.0.1:3000                -->
<!-- ========================================================== -->
<configuration>
  <system.webServer>

    <!-- Remove the X-Powered-By header -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="camera=self, microphone=(), geolocation=self" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Strict-Transport-Security" value="max-age=63072000; includeSubDomains; preload" />
      </customHeaders>
    </httpProtocol>

    <!-- Hide IIS server token -->
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>

    <!-- URL Rewrite + ARR reverse proxy -->
    <rewrite>
      <rules>

        <!-- 1. Redirect www to non-www apex -->
        <rule name="WWW to non-WWW" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^www\.brickquotepro\.com$" />
          </conditions>
          <action type="Redirect" url="https://brickquotepro.com/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 2. Redirect HTTP to HTTPS (only when Cloudflare is not already terminating HTTPS) -->
        <rule name="HTTP to HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
            <!-- Skip this rule if Cloudflare already sent the request as HTTPS -->
            <add input="{HTTP_X_FORWARDED_PROTO}" pattern="https" negate="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 3. Legacy clean redirects -->
        <rule name="Redirect ar-measure to measure" stopProcessing="true">
          <match url="^ar-measure/?(.*)" />
          <action type="Redirect" url="https://brickquotepro.com/measure/{R:1}" redirectType="Permanent" />
        </rule>
        <rule name="Redirect brick-fence-calculator to quote" stopProcessing="true">
          <match url="^brick-fence-calculator/?(.*)" />
          <action type="Redirect" url="https://brickquotepro.com/quote/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 4. Reverse proxy all traffic to Next.js (preserves query strings automatically) -->
        <rule name="Reverse Proxy to Next.js" stopProcessing="false">
          <match url="(.*)" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^https?://" />
          </conditions>
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
        </rule>

      </rules>

      <!-- Preserve original client info for Next.js -->
      <serverVariables>
        <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
        <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
        <set name="HTTP_X_FORWARDED_PROTO" value="https" />
        <set name="HTTP_X_REAL_IP" value="{REMOTE_ADDR}" />
      </serverVariables>

    </rewrite>

    <!-- Compression (gzip + dynamic) -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    <httpCompression>
      <dynamicTypes>
        <clear />
        <add mimeType="text/*" enabled="true" />
        <add mimeType="message/*" enabled="true" />
        <add mimeType="application/x-javascript" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="application/atom+xml" enabled="true" />
        <add mimeType="application/rss+xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </dynamicTypes>
      <staticTypes>
        <clear />
        <add mimeType="text/*" enabled="true" />
        <add mimeType="message/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/atom+xml" enabled="true" />
        <add mimeType="application/xaml+xml" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </staticTypes>
    </httpCompression>

    <!-- Static file caching (browser cache for non-Next.js static assets) -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
    </staticContent>

  </system.webServer>
</configuration>
